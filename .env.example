# NyayaVedika — Environment Variables
# Copy this file to .env.local for local development
# In GitHub Actions → use Settings > Environments > NyayaVedika > Secrets
# In Vercel → use Project Settings > Environment Variables

# ─── AI Provider ───────────────────────────────────────────────
# Which AI provider to use: "nvidia", "deepseek", "anthropic", or "gemini"
VITE_AI_PROVIDER=nvidia

# ─── NVIDIA API (default — free Llama 4 Maverick) ─────────────
# Get your key: https://build.nvidia.com/
VITE_NVIDIA_API_KEY=

# ─── DeepSeek (cheap/free) ────────────────────────────────────
# Get your key: https://platform.deepseek.com/api_keys
VITE_DEEPSEEK_API_KEY=

# ─── Anthropic Claude ──────────────────────────────────────────
# Get your key: https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=

# ─── Google Gemini ─────────────────────────────────────────────
# Get your key: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# ─── App Config ────────────────────────────────────────────────
VITE_APP_NAME=NyayaVedika
VITE_APP_ENV=production
