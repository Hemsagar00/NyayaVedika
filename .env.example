# NyayaVedika — Environment Variables
# Copy this file to .env.local for local development
# In GitHub Actions → use Settings > Environments > NyayaVedika > Secrets
# In Vercel → use Project Settings > Environment Variables

# ─── AI Provider ───────────────────────────────────────────────
# Which AI provider to use: "lmstudio", "nvidia", "deepseek", "anthropic", or "gemini"
# Default: lmstudio in local dev, nvidia in production
VITE_AI_PROVIDER=lmstudio

# ─── LM Studio (local — primary, zero cost) ─────────────────────
# Download LM Studio: https://lmstudio.ai/
# Load any model (e.g. Llama 3, Mistral, Phi) and start the local server
# Default endpoint: http://localhost:1234/v1
VITE_LMSTUDIO_API_KEY=lm-studio

# ─── NVIDIA API (backup — free tier available) ──────────────────
# Get your key: https://build.nvidia.com/
VITE_NVIDIA_API_KEY=

# ─── DeepSeek (cheap/free) ────────────────────────────────────
# Get your key: https://platform.deepseek.com/api_keys
VITE_DEEPSEEK_API_KEY=

# ─── Anthropic Claude ──────────────────────────────────────────
# Get your key: https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=

# ─── Google Gemini ─────────────────────────────────────────────
# Get your key: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# ─── App Config ────────────────────────────────────────────────
VITE_APP_NAME=NyayaVedika
VITE_APP_ENV=production
