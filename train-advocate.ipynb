from google.colab import drive
drive.mount('/content/drive')

# Folder path (update if different)
DRIVE_FOLDER = "/content/drive/MyDrive/Legal_Datasets"  # adjust path as needed
OUTPUT_DIR = "/content/drive/MyDrive/NyayaVedika_Model"

import os
os.makedirs(OUTPUT_DIR, exist_ok=True)

# ═══════════════════════════════════════════════════════
# STEP 2: Install Unsloth
# ═══════════════════════════════════════════════════════
!pip install unsloth
